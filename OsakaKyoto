 ```react
import React, { useState, useEffect } from 'react';
import { initializeApp } from 'firebase/app';
import { getAuth, signInWithCustomToken, signInAnonymously, onAuthStateChanged } from 'firebase/auth';
import { getFirestore, doc, setDoc, onSnapshot } from 'firebase/firestore';

// --- Firebase Initialization ---
const firebaseConfig = typeof __firebase_config !== 'undefined' ? JSON.parse(__firebase_config) : {};
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';

// --- Minimalist Icons (Inline SVGs) ---
const ChevronLeftIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
    <polyline points="15 18 9 12 15 6"></polyline>
  </svg>
);

const PlusIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
    <line x1="12" y1="5" x2="12" y2="19"></line>
    <line x1="5" y1="12" x2="19" y2="12"></line>
  </svg>
);

const TrashIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
    <polyline points="3 6 5 6 21 6"></polyline>
    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
  </svg>
);

const MapPinIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
    <circle cx="12" cy="10" r="3"></circle>
  </svg>
);

const RouteIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
    <circle cx="6" cy="19" r="3"></circle>
    <path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15"></path>
    <circle cx="18" cy="5" r="3"></circle>
  </svg>
);

// 新增：上下移動的箭頭圖示
const ArrowUpIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
    <line x1="12" y1="19" x2="12" y2="5"></line>
    <polyline points="5 12 12 5 19 12"></polyline>
  </svg>
);

const ArrowDownIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
    <line x1="12" y1="5" x2="12" y2="19"></line>
    <polyline points="19 12 12 19 5 12"></polyline>
  </svg>
);

export default function App() {
  // --- State ---
  const [user, setUser] = useState(null);
  const [view, setView] = useState('lists');
  const [lists, setLists] = useState([]);
  const [routes, setRoutes] = useState({}); 
  const [activeListId, setActiveListId] = useState(null);
  const [newLocationInput, setNewLocationInput] = useState('');
  const [loading, setLoading] = useState(false);
  const [errorMsg, setErrorMsg] = useState('');

  // --- 1. Firebase Authentication ---
  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (error) {
        console.error("驗證連線失敗", error);
      }
    };
    initAuth();
    
    const unsubscribe = onAuthStateChanged(auth, (currentUser) => {
      setUser(currentUser);
    });
    return () => unsubscribe();
  }, []);

  // --- 2. 雲端資料同步 ---
  useEffect(() => {
    if (!user) return;
    const docRef = doc(db, 'artifacts', appId, 'users', user.uid, 'travelData', 'main');
    const unsubscribe = onSnapshot(docRef, (docSnap) => {
      if (docSnap.exists()) {
        const data = docSnap.data();
        if (data.lists) setLists(data.lists);
        if (data.routes) setRoutes(data.routes);
      } else {
        const initialLists = [{ id: Date.now(), name: '我的日本自由行', locations: [] }];
        setLists(initialLists);
        setDoc(docRef, { lists: initialLists, routes: {} }, { merge: true });
      }
    }, (error) => {
      console.error("雲端讀取錯誤:", error);
    });
    return () => unsubscribe();
  }, [user]);

  const updateListsToCloud = (newLists) => {
    setLists(newLists);
    if (user) {
      const docRef = doc(db, 'artifacts', appId, 'users', user.uid, 'travelData', 'main');
      setDoc(docRef, { lists: newLists }, { merge: true });
    }
  };

  const updateRoutesToCloud = (newRoutes) => {
    setRoutes(newRoutes);
    if (user) {
      const docRef = doc(db, 'artifacts', appId, 'users', user.uid, 'travelData', 'main');
      setDoc(docRef, { routes: newRoutes }, { merge: true });
    }
  };

  // --- Handlers ---
  const handleAddList = () => {
    const newList = {
      id: Date.now(),
      name: `新行程清單`,
      locations: []
    };
    updateListsToCloud([...lists, newList]);
    setActiveListId(newList.id);
    setView('detail');
  };

  const handleUpdateListName = (e) => {
    const updated = lists.map(l => 
      l.id === activeListId ? { ...l, name: e.target.value } : l
    );
    updateListsToCloud(updated);
  };

  const handleAddLocation = (e) => {
    e.preventDefault();
    if (!newLocationInput.trim()) return;
    
    const updated = lists.map(l => {
      if (l.id === activeListId) {
        return { ...l, locations: [...l.locations, newLocationInput.trim()] };
      }
      return l;
    });
    
    updateListsToCloud(updated);
    setNewLocationInput('');
    updateRoutesToCloud({ ...routes, [activeListId]: null }); 
  };

  const handleRemoveLocation = (index) => {
    const updated = lists.map(l => {
      if (l.id === activeListId) {
        return { ...l, locations: l.locations.filter((_, i) => i !== index) };
      }
      return l;
    });
    updateListsToCloud(updated);
    updateRoutesToCloud({ ...routes, [activeListId]: null });
  };

  // 新增：處理地點上下移動的邏輯
  const handleMoveLocation = (index, direction) => {
    const listToUpdate = lists.find(l => l.id === activeListId);
    if (!listToUpdate) return;

    const newLocations = [...listToUpdate.locations];
    
    if (direction === 'up' && index > 0) {
      // 和上一個元素交換
      [newLocations[index - 1], newLocations[index]] = [newLocations[index], newLocations[index - 1]];
    } else if (direction === 'down' && index < newLocations.length - 1) {
      // 和下一個元素交換
      [newLocations[index + 1], newLocations[index]] = [newLocations[index], newLocations[index + 1]];
    } else {
      return; // 到底或到頂了，不動作
    }

    const updatedLists = lists.map(l => {
      if (l.id === activeListId) {
        return { ...l, locations: newLocations };
      }
      return l;
    });

    updateListsToCloud(updatedLists);
    // 順序改變了，舊的路線就無效了，清空讓使用者重算
    updateRoutesToCloud({ ...routes, [activeListId]: null });
  };

  // --- Gemini API ---
  const fetchWithRetry = async (url, options, retries = 5) => {
    const delays = [1000, 2000, 4000, 8000, 16000];
    for (let i = 0; i < retries; i++) {
      try {
        const response = await fetch(url, options);
        if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
        return await response.json();
      } catch (e) {
        if (i === retries - 1) throw e;
        await new Promise(resolve => setTimeout(resolve, delays[i]));
      }
    }
  };

  const activeList = lists.find(l => l.id === activeListId);

  const handleGenerateRoutes = async () => {
    if (!activeList || activeList.locations.length < 2) return;

    setLoading(true);
    setErrorMsg('');

    const apiKey = ""; 
    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;

    const systemInstruction = `你是一位專業且細心的旅遊交通規劃助手。
任務：接收使用者提供的一系列日本地點，找出準確位置，並規劃地點間的公共交通路線。
要求：
1. 嚴格把關地點真實性，絕不瞎猜。
2. 每一段移動（如A到B），提供三種方案：最方便、最快速、最省錢。
3. 務必以嚴格的JSON陣列格式回傳，不要加上任何 Markdown 語法（例如 \`\`\`json），直接輸出純 JSON 格式。`;

    const userQuery = `請幫我規劃以下地點的交通銜接：\n${activeList.locations.map((l, i) => `${i + 1}. ${l}`).join('\n')}`;

    const payload = {
      contents: [{ parts: [{ text: userQuery }] }],
      systemInstruction: { parts: [{ text: systemInstruction }] },
      tools: [{ google_search: {} }],
      generationConfig: {
        responseMimeType: "application/json",
        responseSchema: {
          type: "ARRAY",
          items: {
            type: "OBJECT",
            properties: {
              from: { type: "STRING", description: "起點名稱" },
              to: { type: "STRING", description: "終點名稱" },
              options: {
                type: "ARRAY",
                items: {
                  type: "OBJECT",
                  properties: {
                    label: { type: "STRING", description: "方案標籤，例如：🌟 最方便, ⚡ 最快速, 💰 最省錢" },
                    transport: { type: "STRING", description: "交通工具與路線，例如：地鐵銀座線" },
                    details: { type: "STRING", description: "起迄站名與換乘指示" },
                    time: { type: "STRING", description: "預估花費時間" },
                    price: { type: "STRING", description: "大約票價" }
                  }
                }
              }
            }
          }
        }
      }
    };

    try {
      const data = await fetchWithRetry(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const jsonText = data.candidates?.[0]?.content?.parts?.[0]?.text;
      
      if (jsonText) {
        const cleanedText = jsonText.replace(/```json\n?/g, '').replace(/```\n?/g, '').trim();
        const parsedRoutes = JSON.parse(cleanedText);
        updateRoutesToCloud({ ...routes, [activeListId]: parsedRoutes });
      } else {
        throw new Error("沒有收到路線資料");
      }
    } catch (error) {
      console.error("API 錯誤或解析失敗:", error);
      setErrorMsg('抱歉，管家在查路線時網路稍微卡住了，我們再按一次好嗎？');
    } finally {
      setLoading(false);
    }
  };

  const currentRoutes = routes[activeListId];

  return (
    <div className="min-h-screen bg-white font-sans selection:bg-blue-100 relative">
      
      {view === 'lists' ? (
        
        <div className="max-w-2xl mx-auto w-full p-6 animate-fade-in">
          <div className="flex justify-between items-end border-b border-gray-200 pb-4 mb-6">
            <h1 className="text-3xl font-light text-gray-800 tracking-wide">行程清單</h1>
            <button 
              onClick={handleAddList}
              className="flex items-center gap-1 text-blue-600 hover:text-blue-800 transition-colors text-sm font-medium"
            >
              <PlusIcon /> 新增清單
            </button>
          </div>

          <div className="space-y-3">
            {lists.length === 0 ? (
               <div className="text-center py-10 text-gray-400">正在讀取雲端記憶...</div>
            ) : (
              lists.map(list => (
                <div 
                  key={list.id} 
                  onClick={() => { setActiveListId(list.id); setView('detail'); }}
                  className="group flex items-center justify-between p-4 bg-white border border-gray-100 rounded-xl hover:border-blue-200 hover:shadow-sm cursor-pointer transition-all"
                >
                  <div>
                    <h2 className="text-lg font-medium text-gray-800 group-hover:text-blue-700 transition-colors">{list.name}</h2>
                    <p className="text-sm text-gray-400 mt-1">
                      {list.locations ? list.locations.length : 0} 個地點
                    </p>
                  </div>
                  <div className="text-gray-300 group-hover:text-blue-400">
                    <ChevronLeftIcon className="rotate-180" />
                  </div>
                </div>
              ))
            )}
          </div>
        </div>

      ) : activeList ? (

        <div className="max-w-2xl mx-auto w-full p-6 animate-fade-in flex flex-col h-[100dvh]">
          {/* Header */}
          <div className="flex items-center gap-4 border-b border-gray-200 pb-4 mb-6 shrink-0">
            <button 
              onClick={() => setView('lists')}
              className="text-gray-400 hover:text-gray-800 transition-colors"
            >
              <ChevronLeftIcon />
            </button>
            <input 
              type="text" 
              value={activeList.name}
              onChange={handleUpdateListName}
              className="text-2xl font-light text-gray-800 bg-transparent border-none outline-none w-full placeholder-gray-300"
              placeholder="輸入清單名稱..."
            />
          </div>

          {/* List Content (Scrollable) */}
          <div className="flex-1 overflow-y-auto no-scrollbar relative">
            
            {/* Add Location Input */}
            <form onSubmit={handleAddLocation} className="mb-8 relative">
              <div className="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                <MapPinIcon />
              </div>
              <input
                type="text"
                value={newLocationInput}
                onChange={(e) => setNewLocationInput(e.target.value)}
                placeholder="搜尋並新增地點（例如：清水寺）..."
                className="w-full pl-10 pr-20 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-400 focus:bg-white transition-all text-gray-700"
              />
              <button 
                type="submit"
                disabled={!newLocationInput.trim()}
                className="absolute inset-y-1 right-1 px-4 text-sm font-medium text-white bg-gray-800 rounded-md hover:bg-black disabled:opacity-50 transition-colors cursor-pointer"
              >
                確認
              </button>
            </form>

            {/* Locations & Inline Routes */}
            {!activeList.locations || activeList.locations.length === 0 ? (
              <div className="text-center py-12 text-gray-400 font-light">
                尚未新增任何地點
              </div>
            ) : (
              <div className="relative">
                {activeList.locations.map((loc, idx) => (
                  <div key={idx} className="relative">
                    
                    {/* Location Node - 新增了移動跟刪除區塊 */}
                    <div className="flex items-center gap-3 bg-white border border-gray-200 p-4 rounded-xl shadow-sm z-10 relative">
                      <div className="w-6 h-6 rounded-full bg-blue-50 border border-blue-200 text-blue-600 flex items-center justify-center text-xs font-bold shrink-0">
                        {idx + 1}
                      </div>
                      <div className="flex-1 text-gray-800 font-medium text-lg truncate">{loc}</div>
                      
                      {/* 右側操作按鈕區 */}
                      <div className="flex items-center gap-1 shrink-0 text-gray-300">
                        <button 
                          onClick={() => handleMoveLocation(idx, 'up')}
                          disabled={idx === 0}
                          className="hover:text-blue-500 disabled:opacity-20 disabled:hover:text-gray-300 p-1 transition-colors cursor-pointer"
                          title="往上移"
                        >
                          <ArrowUpIcon />
                        </button>
                        <button 
                          onClick={() => handleMoveLocation(idx, 'down')}
                          disabled={idx === activeList.locations.length - 1}
                          className="hover:text-blue-500 disabled:opacity-20 disabled:hover:text-gray-300 p-1 transition-colors cursor-pointer"
                          title="往下移"
                        >
                          <ArrowDownIcon />
                        </button>
                        
                        <div className="w-[1px] h-4 bg-gray-200 mx-1"></div>
                        
                        <button 
                          onClick={() => handleRemoveLocation(idx)}
                          className="hover:text-red-500 p-1 transition-colors cursor-pointer"
                          title="刪除"
                        >
                          <TrashIcon />
                        </button>
                      </div>
                    </div>

                    {/* Inter-location Route Display */}
                    {idx < activeList.locations.length - 1 && (
                      <div className="ml-7 border-l-2 border-dashed border-gray-200 py-6 pl-8 pr-2 relative my-1">
                        
                        <div className="absolute -left-[9px] top-1/2 -translate-y-1/2 w-4 h-4 bg-white border-2 border-gray-200 rounded-full"></div>

                        {currentRoutes && currentRoutes[idx] ? (
                          <div className="space-y-3 bg-gray-50 rounded-lg p-4 border border-gray-100">
                            {currentRoutes[idx].options?.map((opt, optIdx) => (
                              <div key={optIdx} className="bg-white p-3 rounded border border-gray-100 flex flex-col sm:flex-row sm:items-center justify-between gap-2 shadow-sm text-sm">
                                <div className="flex-1">
                                  <div className="font-medium text-gray-800 mb-1 flex items-center gap-1.5">
                                    <span>{opt.label}</span>
                                  </div>
                                  <div className="text-gray-600">
                                    <span className="font-semibold text-blue-700">{opt.transport}</span>
                                    <span className="mx-2 text-gray-300">|</span>
                                    {opt.details}
                                  </div>
                                </div>
                                <div className="flex sm:flex-col items-center sm:items-end gap-3 sm:gap-1 text-gray-500 shrink-0">
                                  <span className="bg-gray-100 px-2 py-0.5 rounded text-xs font-medium">{opt.time}</span>
                                  <span className="font-medium">{opt.price}</span>
                                </div>
                              </div>
                            ))}
                          </div>
                        ) : (
                          <div className="text-sm text-gray-400 italic flex items-center gap-2">
                             往下一個地點
                          </div>
                        )}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}
            
            {errorMsg && (
              <div className="mt-4 p-3 bg-red-50 text-red-600 text-sm rounded-lg border border-red-100 text-center">
                {errorMsg}
              </div>
            )}

            {/* Action Button */}
            {activeList.locations && activeList.locations.length >= 2 && !currentRoutes && (
              <div className="mt-8 mb-4">
                <button
                  onClick={handleGenerateRoutes}
                  disabled={loading}
                  className={`w-full py-4 rounded-xl shadow-lg font-medium flex items-center justify-center gap-2 transition-all cursor-pointer ${
                    loading 
                      ? 'bg-gray-600 text-white cursor-wait' 
                      : 'bg-black text-white hover:bg-gray-800'
                  }`}
                >
                  {loading ? (
                    <div className="flex items-center gap-2">
                      <div className="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                      <span>管家正在精算路線中...</span>
                    </div>
                  ) : (
                    <>
                      <RouteIcon />
                      <span>開始安排路線</span>
                    </>
                  )}
                </button>
              </div>
            )}

            <div className="h-64 shrink-0 w-full"></div>

          </div>
        </div>

      ) : null}
      
      <style dangerouslySetInnerHTML={{__html: `
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      `}} />
    </div>
  );
}


